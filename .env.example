# ── fal.ai ──────────────────────────────────────────────
# Get at: https://fal.ai/dashboard/keys
FAL_KEY=your_fal_api_key

# ── RunPod Serverless ────────────────────────────────────
# Get at: https://console.runpod.io/user/settings → API Keys
RUNPOD_API_KEY=your_runpod_api_key
# Serverless endpoint IDs (from the endpoint page URL or “Endpoint ID” field)
RUNPOD_FAST_ENDPOINT_ID=
RUNPOD_PREMIUM_ENDPOINT_ID=
# Backend routing:
# - fast:    runpod | fal | local
# - premium: runpod | fal | local
FAST_TIER_BACKEND=runpod
PREMIUM_TIER_BACKEND=runpod

# ── Cloudflare R2 ────────────────────────────────────────
# Create bucket at: https://dash.cloudflare.com → R2
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=headshots
R2_PUBLIC_URL=https://pub-xxxx.r2.dev   # your public R2 domain

# ── Upstash Redis (job state / DB) ───────────────────────
# Free tier at: https://upstash.com
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token

# ── Stripe ───────────────────────────────────────────────
# Get at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx

# ── Resend (email) ───────────────────────────────────────
# Free tier: 3,000 emails/mo — https://resend.com
RESEND_API_KEY=re_xxxx
EMAIL_FROM=headshots@yourdomain.com

# ── PostgreSQL ───────────────────────────────────────────
# Local Docker: postgresql://portraly:portraly_dev@localhost:5434/portraly
# Production (Neon free tier): https://neon.tech
DATABASE_URL=postgresql://portraly:portraly_dev@localhost:5434/portraly

# ── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
PRICE_USD=5900   # price in cents ($59.00)
